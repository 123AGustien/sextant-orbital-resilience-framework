      "Relay": ["Ground"],
      "Ground": []
    },
    "initial_conditions": {
      "Orbital": 1,
      "Relay": 1,
      "Ground": 1
    }
  },

  "scenario": {
    "name": "orbital_resilience_scenario",
    "type": "cascade_analysis",
    "parameters": {
      "stress_level": 5,
      "perturbation_vector": {
        "Orbital": -0.3
      },
      "constraints": [
        "redundancy_activation",
        "signal_delay_tolerance",
        "self_recovery_enabled"
      ]
    }
  }
