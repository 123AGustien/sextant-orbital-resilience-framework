from fastapi import Request, HTTPException
from core.auth import validate_api_key, get_tier
from core.usage import log_request, check_limit


async def api_key_middleware(request: Request, call_next):
    """
    SaaS middleware:
    - Validates API key
    - Checks tier limits
    - Logs usage
    - Blocks unauthorized requests
    """

    # Only protect SaaS endpoints
    if request.url.path.startswith("/simulation") or request.url.path.startswith("/risk"):

        api_key = request.headers.get("x-api-key")

        # 1. Validate API key
        if not api_key or not validate_api_key(api_key):
            raise HTTPException(
                status_code=401,
                detail="Invalid or missing API key"
            )

        # 2. Get user tier
        tier = get_tier(api_key)

        # 3. Check usage limit
        if not check_limit(api_key, tier):
            raise HTTPException(
                status_code=429,
                detail="Usage limit exceeded for tier"
            )

        # 4. Log request (before execution)
        log_request(api_key)

    # Continue request flow
    response = await call_next(request)
    return response
